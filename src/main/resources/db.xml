<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-3.2.xsd">

    <bean id="dataSource" class="org.springframework.jdbc.datasource.DriverManagerDataSource">
        <property name="driverClassName" value="org.h2.Driver" />
        <property name="url" value="jdbc:h2:file:./db/events;DB_CLOSE_DELAY=-1" />
        <property name="username" value="sa" />
        <property name="password" value="" />
    </bean>

    <bean id="jdbcTemplate" class="org.springframework.jdbc.core.JdbcTemplate">
        <constructor-arg ref="dataSource" />
    </bean>

    <bean id="dbLogger" class="com.yet.spring.core.loggers.DBLogger"
          init-method="init" destroy-method="destroy">
        <constructor-arg ref="jdbcTemplate"/>
    </bean>
    <bean id="h2WebServer" class="org.h2.tools.Server"
          factory-method="createWebServer"
          init-method="start"
          destroy-method="stop">
        <constructor-arg value="-web,-webPort,8082,-webAllowOthers"/>
    </bean>

</beans>